POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aicourt
POSTGRES_PASSWORD=aicourt_secret
POSTGRES_DB=aicourt

REDIS_URL=redis://localhost:6379/0

APP_PORT=8000
APP_SECRET_KEY=change-me-in-production
